# Copy to .env and adjust as needed. Used by local runs and CI/CD scripts.

# Local service ports (match docker-compose and ECS task definitions)
CUSTOMER_SERVICE_PORT=3000
EMPLOYEE_SERVICE_PORT=3001

# AWS
AWS_DEFAULT_REGION=eu-west-1

# ECR repository names and image tag (build/deploy)
ECR_REPO_CUSTOMER=customer-service
ECR_REPO_EMPLOYEE=employee-service
IMAGE_TAG=latest
